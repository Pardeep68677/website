
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a marketplace user (Customer or Barber).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "barber"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phoneNumber", "role"]
    },
    "BarberShop": {
      "title": "Barber Shop",
      "description": "Details about a barber's shop and services.",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "shopName": { "type": "string" },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "imageUrl": { "type": "string" }
      },
      "required": ["ownerUid", "shopName", "address"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A haircut transaction or appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceName": { "type": "string" },
        "originalPrice": { "type": "number" },
        "discountedPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "barberId", "status"]
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles for both customers and barbers."
    },
    "/shops/{shopId}": {
      "schema": "BarberShop",
      "description": "Shop details for registered barbers."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Transaction records for marketplace activity."
    }
  }
}
